# ============================================================
#  Clash Dev Analyser — Worker Environment Variables
#  Copy this file to .dev.vars for local development.
#  In Cloudflare Dashboard: go to Workers > Settings > Variables
# ============================================================

# [REQUIRED] GitHub Personal Access Token
# Create one at: https://github.com/settings/tokens
# Scopes needed: public_repo (read only is fine)
GITHUB_PAT=ghp_your_token_here

# [OPTIONAL] ClashDB caching — skip if you don't want caching
# Self-hostable: https://github.com/your-clashdb-fork
CLASHDB_URL=https://your-clashdb-instance.vercel.app
CLASHDB_API_KEY=your_clashdb_api_key

# [OPTIONAL] How long to cache results in seconds (default: 3600 = 1 hour)
CACHE_TTL_SECONDS=3600

# [OPTIONAL] How many repos to scan for language stats (default: 8, max: 15)
# Keep this low on CF free plan to avoid hitting the 50 subrequest limit
LANGUAGE_REPO_LIMIT=8
